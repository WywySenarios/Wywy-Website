{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "wywywebsite-astro",
  "compatibility_date": "2025-11-27",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "ericzhu.me",
      "custom_domain": true,
    },
  ],
}
